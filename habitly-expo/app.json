{
  "expo": {
    "name": "Habitly",
    "slug": "habitly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/image.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#1D9E75"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shadi.habitly"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/image.png",
        "backgroundColor": "#1D9E75"
      },
      "package": "com.shadi.habitly",
      "versionCode": 1
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "habitly",
    "experiments": {
      "typedRoutes": false
    }
  }
}
